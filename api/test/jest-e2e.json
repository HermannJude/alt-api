{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": ["**/*.(t|j)s"],
  "coverageDirectory": "../coverage",
  "testEnvironment": "node",
  "testPathIgnorePatterns": ["/categories/", "/usage-metrics/", "/prisma/"],
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/$1",
    "^generated/(.*)$": "<rootDir>/generated/$1"
  }
}
